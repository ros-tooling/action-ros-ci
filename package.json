{
	"name": "action-ros-ci",
	"version": "0.4.5",
	"description": "GitHub Action compiling and testing a ROS 2 package",
	"main": "lib/main.js",
	"scripts": {
		"prepare": "husky",
		"build": "ncc build src/run.ts -o dist",
		"fixup": "eslint . --fix",
		"lint": "eslint .",
		"prettier": "prettier --write .",
		"test": "tsc --noEmit && jest --coverage"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ros-tooling/action-ros-ci.git"
	},
	"keywords": [
		"actions",
		"ros",
		"ci"
	],
	"author": "ROS 2 Tooling Working Group",
	"license": "Apache-2.0",
	"licenses": [
		{
			"type": "Apache-2.0",
			"url": "http://www.apache.org/licenses/LICENSE-2.0"
		}
	],
	"bugs": {
		"url": "https://github.com/ros-tooling/action-ros-ci/issues"
	},
	"dependencies": {
		"@actions/core": "^3.0.0",
		"@actions/exec": "^3.0.0",
		"@actions/github": "^9.0.0",
		"@actions/io": "^3.0.2",
		"async-retry": "^1.3.3"
	},
	"devDependencies": {
		"@types/jest": "^30.0.0",
		"@types/node": "^25.5.0",
		"@typescript-eslint/eslint-plugin": "^8.57.0",
		"@typescript-eslint/parser": "^8.57.0",
		"@vercel/ncc": "^0.38.4",
		"acorn": "^8.16.0",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"husky": "^9.1.7",
		"jest": "^30.3.0",
		"jest-circus": "^30.3.0",
		"lint-staged": "^16.3.3",
		"prettier": "3.8.1",
		"ts-jest": "^29.4.6",
		"typescript": "^5.9.3"
	},
	"husky": {
		"hooks": {
			"pre-commit": "lint-staged"
		}
	}
}
